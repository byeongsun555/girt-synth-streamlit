# Hugging Face access token (required for FLUX gated models).
# https://huggingface.co/settings/tokens
HF_TOKEN=

# MinIO object storage (defaults are fine for local docker-compose)
# MINIO_ENABLED=true
# MINIO_ENDPOINT=minio:9000
# MINIO_PUBLIC_ENDPOINT=localhost:9020
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=synthetic-data
# MINIO_SECURE=false

# Host ports for MinIO (override if defaults clash)
# MINIO_API_PORT=9020
# MINIO_CONSOLE_PORT=9021
